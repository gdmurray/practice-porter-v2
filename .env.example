# Sanity project configuration (from `npx sanity@latest init --env`)
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# Visual Editing (Presentation Tool)
# Set to "true" to allow ?preview=true pages to use the draft perspective
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=true

# Required when PUBLIC_SANITY_VISUAL_EDITING_ENABLED is true
# Create a Viewer token at https://sanity.io/manage (API > Tokens)
SANITY_API_READ_TOKEN=

# Base URL the Presentation Tool loads for preview (defaults to current Studio origin)
# Set this if your front-end runs on a different URL than the Studio
# PUBLIC_SANITY_PREVIEW_URL=http://localhost:4321
