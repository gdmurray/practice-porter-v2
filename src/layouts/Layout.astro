---
import { VisualEditing } from "@sanity/astro/visual-editing";
import jakartaFontUrl from "@fontsource-variable/plus-jakarta-sans/files/plus-jakarta-sans-latin-wght-normal.woff2?url";
import playfairFontUrl from "@fontsource-variable/playfair-display/files/playfair-display-latin-wght-normal.woff2?url";
import GoogleAnalytics from "../components/analytics/GoogleAnalytics.astro";
import MicrosoftClarity from "../components/analytics/MicrosoftClarity.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  siteName?: string;
  canonicalUrl?: string;
  preview?: boolean;
  jsonLd?: object | object[] | null;
}

const {
  title = "Practice Porter — Intelligence Behind Every Call",
  description,
  image,
  siteName,
  canonicalUrl,
  preview = false,
  jsonLd,
} = Astro.props;

const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";

const isStudio = Astro.url.pathname.startsWith("/studio");
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;
const clarityId = import.meta.env.PUBLIC_CLARITY_ID as string | undefined;
const loadAnalytics = !preview && !isStudio;

const resolvedCanonical = canonicalUrl ?? Astro.url.href;
const jsonLdItems = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={resolvedCanonical} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {siteName && <meta property="og:site_name" content={siteName} />}
    {image && <meta property="og:image" content={image} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}

    {jsonLdItems.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={jakartaFontUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={playfairFontUrl} crossorigin />

    {loadAnalytics && gaId && <GoogleAnalytics measurementId={gaId} />}
    {loadAnalytics && clarityId && <MicrosoftClarity clarityId={clarityId} />}
  </head>
  <body>
    <slot />
    {
      visualEditingEnabled && preview && (
        <a
          class="exit-preview"
          href={Astro.url.pathname}
          data-astro-reload
        >
          Exit preview
        </a>
      )
    }
    <VisualEditing enabled={visualEditingEnabled && preview} zIndex={1000} />
    <script define:vars={{ bookingUrl: import.meta.env.PUBLIC_GOOGLE_CALENDAR_BOOKING_URL }}>
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener("click", (e) => {
          e.preventDefault();
          const href = anchor.getAttribute("href");
          const target = href ? document.querySelector(href) : null;
          if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      // Google Calendar scheduling-button loader.
      // Layout owns script/CSS injection (once per page). Any element with
      // data-cta-type="book_meeting" triggers the popup via proxy-click on
      // the hidden button that Google's script renders.
      const GCAL_SCRIPT = "gcal-scheduling-script";
      const GCAL_CSS    = "gcal-scheduling-css";

      // The hidden wrapper Google's button is mounted inside.
      // Google inserts its button as a sibling *after* the target div,
      // so we hide the whole wrapper to keep it off-screen.
      let _gcalWrapper = null;
      let _gcalButton = null;
      let _pendingOpen = false;
      let _mounted = false;

      function injectGcalAssets() {
        if (!document.getElementById(GCAL_CSS)) {
          const css = document.createElement("link");
          css.id = GCAL_CSS;
          css.rel = "stylesheet";
          css.href = "https://calendar.google.com/calendar/scheduling-button-script.css";
          document.head.appendChild(css);
        }
      }

      function mountGcalButton(onReady) {
        if (_mounted) { if (onReady) onReady(); return; }

        injectGcalAssets();

        // Hidden wrapper to contain Google's injected button element.
        if (!_gcalWrapper) {
          const wrapper = document.createElement("div");
          wrapper.id = "gcal-button-wrapper";
          wrapper.style.cssText = "position:fixed;width:0;height:0;overflow:hidden;opacity:0;pointer-events:none;";
          const targetDiv = document.createElement("div");
          targetDiv.id = "gcal-button-target";
          wrapper.appendChild(targetDiv);
          document.body.appendChild(wrapper);
          _gcalWrapper = wrapper;
        }

        const targetDiv = _gcalWrapper.querySelector("#gcal-button-target");

        const doMount = () => {
          if (_mounted) { if (onReady) onReady(); return; }
          _mounted = true;

          window.calendar.schedulingButton.load({
            url: bookingUrl,
            color: "#0B1D3A",
            label: "Book an appointment",
            target: targetDiv,
          });

          // Google inserts its button as a sibling of targetDiv; poll until found.
          let attempts = 0;
          const poll = setInterval(() => {
            const btn = targetDiv.nextElementSibling;
            if (btn) {
              _gcalButton = btn;
              clearInterval(poll);
              if (onReady) onReady();
              if (_pendingOpen) {
                _pendingOpen = false;
                btn.click();
              }
            } else if (++attempts > 40) {
              clearInterval(poll);
            }
          }, 100);
        };

        const existing = document.getElementById(GCAL_SCRIPT);
        if (window.calendar && window.calendar.schedulingButton) {
          doMount();
        } else if (existing) {
          existing.addEventListener("load", doMount, { once: true });
        } else {
          const script = document.createElement("script");
          script.id = GCAL_SCRIPT;
          script.src = "https://calendar.google.com/calendar/scheduling-button-script.js";
          script.async = true;
          script.addEventListener("load", doMount, { once: true });
          document.body.appendChild(script);
        }
      }

      // Preload/mount if any book_meeting element is on the page.
      if (document.querySelector('[data-cta-type="book_meeting"]') || document.getElementById("book-meeting")) {
        mountGcalButton(null);
      }

      // Intercept clicks on any element with data-cta-type="book_meeting".
      document.addEventListener("click", (e) => {
        const trigger = e.target && e.target.closest('[data-cta-type="book_meeting"]');
        if (!trigger) return;
        e.preventDefault();
        if (_gcalButton) {
          _gcalButton.click();
        } else {
          _pendingOpen = true;
          mountGcalButton(null);
        }
      });

      // Analytics: delegated click tracking (separate from the GCal proxy above).
      function classifyLinkType(link, href) {
        if (link.getAttribute("target") === "_blank") return "external";
        if (href.startsWith("mailto:")) return "email";
        if (href.startsWith("tel:")) return "phone";
        if (href.startsWith("#")) return "anchor";
        return "internal";
      }

      function trackClickEvent(name, params) {
        if (typeof window.gtag !== "function") return;
        window.gtag("event", name, params);
      }

      document.addEventListener("click", (e) => {
        const link = e.target && e.target.closest("a, [data-cta-type]");
        if (!link) return;
        const href = link.getAttribute("href") || "";
        const location = link.closest("nav")
          ? "nav"
          : link.closest("footer")
            ? "footer"
            : (link.closest("section[id]") && link.closest("section[id]").id) || "other";
        const isBookMeeting =
          link.matches('[data-cta-type="book_meeting"]') ||
          (bookingUrl && href.startsWith(bookingUrl));

        trackClickEvent(isBookMeeting ? "book_meeting_click" : "cta_click", {
          location,
          link_text: (link.textContent || "").trim().slice(0, 100),
          link_url: href,
          link_type: classifyLinkType(link, href),
        });
      });
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  .exit-preview {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 1001;
    padding: 0.5rem 1rem;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink, #2B1A14);
    background: var(--red, #A32705);
    border-radius: 9999px;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--ink, #2B1A14) 12%, transparent);
  }

  .exit-preview:hover {
    filter: brightness(1.05);
  }
</style>
