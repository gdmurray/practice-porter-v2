---
import { VisualEditing } from "@sanity/astro/visual-editing";
import interFontUrl from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import playfairFontUrl from "@fontsource-variable/playfair-display/files/playfair-display-latin-wght-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  siteName?: string;
  canonicalUrl?: string;
  preview?: boolean;
  jsonLd?: object | object[] | null;
}

const {
  title = "Practice Porter — Intelligence Behind Every Call",
  description,
  image,
  siteName,
  canonicalUrl,
  preview = false,
  jsonLd,
} = Astro.props;

const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";

const resolvedCanonical = canonicalUrl ?? Astro.url.href;
const jsonLdItems = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={resolvedCanonical} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {siteName && <meta property="og:site_name" content={siteName} />}
    {image && <meta property="og:image" content={image} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}

    {jsonLdItems.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interFontUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={playfairFontUrl} crossorigin />
  </head>
  <body>
    <slot />
    {
      visualEditingEnabled && preview && (
        <a
          class="exit-preview"
          href={Astro.url.pathname}
          data-astro-reload
        >
          Exit preview
        </a>
      )
    }
    <VisualEditing enabled={visualEditingEnabled && preview} zIndex={1000} />
    <script>
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener("click", (e) => {
          e.preventDefault();
          const href = (anchor as HTMLAnchorElement).getAttribute("href");
          const target = href ? document.querySelector(href) : null;
          if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      // Calendly loader — Layout owns script/CSS injection so it happens exactly once.
      // BookMeeting.tsx only calls initInlineWidget; it never creates the script tag.
      const CALENDLY_SCRIPT = "calendly-widget-script";
      const CALENDLY_CSS    = "calendly-widget-css";

      // Cache the popup overlay so we can hide/show it instead of recreating
      // the iframe (and its loading state) on every click.
      let _calendlyOverlay: HTMLElement | null = null;

      function loadCalendly(onReady?: () => void) {
        if (!document.getElementById(CALENDLY_CSS)) {
          const css = document.createElement("link");
          css.id = CALENDLY_CSS;
          css.rel = "stylesheet";
          css.href = "https://assets.calendly.com/assets/external/widget.css";
          document.head.appendChild(css);
        }
        const existing = document.getElementById(CALENDLY_SCRIPT);
        if ((window as any).Calendly) {
          onReady?.();
        } else if (existing) {
          if (onReady) existing.addEventListener("load", onReady, { once: true });
        } else {
          const script = document.createElement("script");
          script.id = CALENDLY_SCRIPT;
          script.src = "https://assets.calendly.com/assets/external/widget.js";
          script.async = true;
          if (onReady) script.addEventListener("load", onReady, { once: true });
          document.body.appendChild(script);
        }
      }

      function hideCalendlyPopup() {
        if (_calendlyOverlay) _calendlyOverlay.style.display = "none";
        document.body.style.overflow = "";
      }

      function openCalendlyPopup(url: string) {
        // Reuse the cached overlay — no reload, no loading spinner on subsequent opens.
        if (_calendlyOverlay) {
          _calendlyOverlay.style.display = "";
          document.body.style.overflow = "hidden";
          return;
        }

        (window as any).Calendly.showPopupWidget(url);
        document.body.style.overflow = "hidden";

        // Calendly creates the overlay synchronously; grab it next frame.
        requestAnimationFrame(() => {
          const overlay = document.querySelector<HTMLElement>(".calendly-overlay");
          if (!overlay) return;
          _calendlyOverlay = overlay;

          // Replace Calendly's close elements with clones that just hide the
          // overlay instead of destroying it (cloneNode strips existing listeners).
          const replaceWithHide = (selector: string) => {
            const el = overlay.querySelector<HTMLElement>(selector);
            if (!el) return;
            const clone = el.cloneNode(true) as HTMLElement;
            clone.addEventListener("click", hideCalendlyPopup);
            el.parentNode?.replaceChild(clone, el);
          };

          replaceWithHide(".calendly-close-overlay");
          replaceWithHide(".calendly-popup-close");
        });
      }

      // Preload if page has Calendly links or the BookMeeting section.
      if (
        document.querySelector('a[href*="calendly.com"]') ||
        document.getElementById("book-meeting")
      ) {
        loadCalendly();
      }

      // Intercept any Calendly anchor click and open as a popup.
      document.addEventListener("click", (e) => {
        const link = (e.target as Element)?.closest("a");
        if (!link) return;
        const href = link.getAttribute("href");
        if (!href?.includes("calendly.com")) return;
        e.preventDefault();
        loadCalendly(() => openCalendlyPopup(href));
      });
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  .exit-preview {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 1001;
    padding: 0.5rem 1rem;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--midnight, #0f172a);
    background: var(--gold, #c9a96e);
    border-radius: 9999px;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--midnight, #0f172a) 12%, transparent);
  }

  .exit-preview:hover {
    filter: brightness(1.05);
  }
</style>
